---
interface Props {
  href: string;
  title: string;
  description: string;
  meta?: string;
  badges?: string[];
  searchText?: string;
  category?: string;
}

const {
  href,
  title,
  description,
  meta,
  badges = [],
  searchText = '',
  category = ''
} = Astro.props;
---

<a
  class="content-card content-card--interactive"
  href={href}
  data-search={searchText.toLowerCase()}
  data-category={category}
>
  <div class="content-card__top">
    {meta ? <p class="content-card__meta">{meta}</p> : <span />}
    <span class="content-card__icon" aria-hidden="true">↗</span>
  </div>
  <div class="content-card__header">
    <h2 class="content-card__title">{title}</h2>
  </div>
  <p class="content-card__description">{description}</p>
  <div class="content-card__footer">
    {badges.length > 0 ? (
      <ul class="pill-list" aria-label="タグ">
        {badges.map((badge) => (
          <li class="pill">{badge}</li>
        ))}
      </ul>
    ) : (
      <span />
    )}
    <span class="content-card__arrow" aria-hidden="true">詳しく読む</span>
  </div>
</a>
