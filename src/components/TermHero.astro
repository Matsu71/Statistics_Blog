---
import MathText from './MathText.astro';

interface Props {
  title: string;
  summary: string;
  facts: {
    label: string;
    value: string;
  }[];
  aliases?: string[];
  tags?: string[];
  takeaways: string[];
}

const { title, summary, facts, aliases = [], tags = [], takeaways } = Astro.props;
---

<header id="takeaways" class="term-hero">
  <div class="term-hero__main">
    <p class="eyebrow">Term</p>
    <h1 class="article-title">{title}</h1>
    <p class="article-summary">
      <MathText text={summary} />
    </p>

    {takeaways.length > 0 && (
      <section class="term-hero__takeaways" aria-labelledby="term-takeaways-title">
        <p class="term-hero__panel-label" id="term-takeaways-title">重要ポイント</p>
        <ul class="check-list">
          {takeaways.map((item) => (
            <li>
              <MathText text={item} />
            </li>
          ))}
        </ul>
      </section>
    )}

    <div class="term-hero__actions">
      <slot />
    </div>

    <div class="term-hero__meta" aria-label="用語情報">
      {facts.map((fact) => (
        <span class="term-hero__meta-item">
          <span class="term-hero__meta-label">{fact.label}</span>
          <span class="term-hero__meta-value">{fact.value}</span>
        </span>
      ))}

      {aliases.length > 0 && (
        <div class="term-hero__meta-group" aria-label="別名">
          <span class="term-hero__meta-label">別名</span>
          {aliases.map((alias) => (
            <span class="pill pill--quiet">{alias}</span>
          ))}
        </div>
      )}

      {tags.length > 0 && (
        <div class="term-hero__meta-group" aria-label="タグ">
          <span class="term-hero__meta-label">タグ</span>
          {tags.map((tag) => (
            <span class="pill pill--quiet">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </div>
</header>
