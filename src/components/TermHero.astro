---
import MathText from './MathText.astro';

interface Props {
  title: string;
  summary: string;
  facts: {
    label: string;
    value: string;
  }[];
  aliases?: string[];
  tags?: string[];
  takeaways: string[];
}

const { title, summary, facts, aliases = [], tags = [], takeaways } = Astro.props;
---

<header class="term-hero">
  <div class="term-hero__main">
    <p class="eyebrow">用語ページ</p>
    <h1 class="article-title">{title}</h1>
    <p class="article-summary">
      <MathText text={summary} />
    </p>
    <div class="term-hero__actions">
      <slot />
    </div>

    {aliases.length > 0 && (
      <div class="term-hero__group">
        <p class="term-hero__panel-label">別名</p>
        <div class="link-row term-hero__tags" aria-label="別名">
          {aliases.map((alias) => (
            <span class="pill">{alias}</span>
          ))}
        </div>
      </div>
    )}

    {tags.length > 0 && (
      <div class="term-hero__group">
        <p class="term-hero__panel-label">タグ</p>
        <div class="link-row term-hero__tags" aria-label="タグ">
          {tags.map((tag) => (
            <span class="pill">{tag}</span>
          ))}
        </div>
      </div>
    )}
  </div>

  <div class="term-hero__side">
    {facts.length > 0 && (
      <section class="term-hero__panel term-hero__facts" aria-labelledby="term-facts-title">
        <p class="term-hero__panel-label" id="term-facts-title">クイック情報</p>
        <dl class="term-hero__facts-grid">
          {facts.map((fact) => (
            <div class="term-hero__fact">
              <dt class="term-hero__fact-label">{fact.label}</dt>
              <dd class="term-hero__fact-value">{fact.value}</dd>
            </div>
          ))}
        </dl>
      </section>
    )}

    <section id="takeaways" class="term-hero__panel term-hero__takeaways" aria-labelledby="term-takeaways-title">
      <p class="term-hero__panel-label" id="term-takeaways-title">この記事でわかること</p>
      <ul class="check-list">
        {takeaways.map((item) => (
          <li>
            <MathText text={item} />
          </li>
        ))}
      </ul>
    </section>
  </div>
</header>
