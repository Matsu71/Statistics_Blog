---
interface Props {
  title: string;
  summary: string;
  metaChips: string[];
  aliases?: string[];
  tags?: string[];
  takeaways: string[];
}

const { title, summary, metaChips, aliases = [], tags = [], takeaways } = Astro.props;
---

<header class="term-hero">
  <p class="eyebrow">用語ページ</p>
  <h1 class="article-title">{title}</h1>
  <p class="article-summary">{summary}</p>
  <div class="term-hero__actions">
    <slot />
  </div>

  <div class="article-meta">
    {metaChips.map((chip) => (
      <span class="meta-chip">{chip}</span>
    ))}
  </div>

  {aliases.length > 0 && (
    <div class="link-row term-hero__tags" aria-label="別名">
      {aliases.map((alias) => (
        <span class="pill">{alias}</span>
      ))}
    </div>
  )}

  {tags.length > 0 && (
    <div class="link-row term-hero__tags" aria-label="タグ">
      {tags.map((tag) => (
        <span class="pill">{tag}</span>
      ))}
    </div>
  )}

  <section id="takeaways" class="term-hero__takeaways" aria-labelledby="term-takeaways-title">
    <h2 id="term-takeaways-title">この記事でわかること</h2>
    <ul class="check-list">
      {takeaways.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>
</header>
