---
import { navigation, siteMeta, withBase } from '../lib/site';

const currentPath = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href={withBase('/')}>
      <span class="brand__eyebrow">Statistics Glossary</span>
      <span class="brand__name">{siteMeta.name}</span>
      <span class="brand__tagline">統計を基礎から学ぶサイト</span>
    </a>

    <nav class="site-nav" aria-label="グローバルナビゲーション">
      <ul class="nav-list">
        {navigation.map((item) => {
          const href = withBase(item.href);
          const active =
            currentPath === href || (item.href !== '/' && currentPath.startsWith(href));

          return (
            <li>
              <a class="nav-link" href={href} aria-current={active ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>
