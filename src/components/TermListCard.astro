---
interface Props {
  href: string;
  title: string;
  description: string;
  categoryLabel: string;
  categoryKey: string;
  levelLabel: string;
  levelKey: string;
  examLabel: string;
  searchText?: string;
}

const {
  href,
  title,
  description,
  categoryLabel,
  categoryKey,
  levelLabel,
  levelKey,
  examLabel,
  searchText = ''
} = Astro.props;
---

<a
  class="term-list-card"
  href={href}
  data-search={searchText.toLowerCase()}
  data-category={categoryKey}
  data-level={levelKey}
>
  <div class="term-list-card__head">
    <div>
      <p class="term-list-card__meta">{categoryLabel} / {levelLabel}</p>
      <h2 class="term-list-card__title">{title}</h2>
    </div>
    <span class="pill">{examLabel}</span>
  </div>
  <p class="term-list-card__description">{description}</p>
  <div class="term-list-card__footer">
    <span class="term-list-card__cta">ページを開く</span>
  </div>
</a>
