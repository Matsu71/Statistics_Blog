---
interface Props {
  href: string;
  title: string;
  description: string;
  categoryLabel: string;
  categoryKey: string;
  levelLabel: string;
  levelKey: string;
  searchText?: string;
}

const {
  href,
  title,
  description,
  categoryLabel,
  categoryKey,
  levelLabel,
  levelKey,
  searchText = ''
} = Astro.props;
---

<a
  class="term-list-card"
  href={href}
  data-search={searchText.toLowerCase()}
  data-category={categoryKey}
  data-level={levelKey}
>
  <div class="term-list-card__text">
    <h2 class="term-list-card__title">{title}</h2>
    <p class="term-list-card__description">{description}</p>
  </div>

  <div class="term-list-card__meta" aria-label="用語の分類">
    <span class="term-list-card__chip">{categoryLabel}</span>
    <span class="term-list-card__chip term-list-card__chip--soft">{levelLabel}</span>
  </div>
</a>
