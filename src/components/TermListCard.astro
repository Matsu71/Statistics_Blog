---
interface Props {
  href: string;
  title: string;
  description: string;
  categoryLabel: string;
  categoryKey: string;
  levelLabel: string;
  levelKey: string;
  searchText?: string;
}

const {
  href,
  title,
  description,
  categoryLabel,
  categoryKey,
  levelLabel,
  levelKey,
  searchText = ''
} = Astro.props;
---

<a
  class="term-list-card"
  href={href}
  data-search={searchText.toLowerCase()}
  data-category={categoryKey}
  data-level={levelKey}
>
  <p class="term-list-card__meta">{categoryLabel} / {levelLabel}</p>
  <h2 class="term-list-card__title">{title}</h2>
  <p class="term-list-card__description">{description}</p>
</a>
