---
interface Props {
  href: string;
  title: string;
  description: string;
  categoryLabel: string;
  categoryKey: string;
  levelLabel: string;
  levelKey: string;
  examLabel: string;
  tags?: string[];
  searchText?: string;
}

const {
  href,
  title,
  description,
  categoryLabel,
  categoryKey,
  levelLabel,
  levelKey,
  examLabel,
  tags = [],
  searchText = ''
} = Astro.props;
---

<a
  class="term-list-card"
  href={href}
  data-search={searchText.toLowerCase()}
  data-category={categoryKey}
  data-level={levelKey}
>
  <div class="term-list-card__topline">
    <span class="term-list-card__chip">{categoryLabel}</span>
    <span class="term-list-card__chip term-list-card__chip--soft">{levelLabel}</span>
  </div>
  <div class="term-list-card__head">
    <div class="term-list-card__text">
      <h2 class="term-list-card__title">{title}</h2>
      <p class="term-list-card__description">{description}</p>
    </div>
    <span class="term-list-card__exam">{examLabel}</span>
  </div>

  {tags.length > 0 && (
    <ul class="pill-list term-list-card__tags" aria-label="タグ">
      {tags.map((tag) => (
        <li class="pill">{tag}</li>
      ))}
    </ul>
  )}

  <div class="term-list-card__footer">
    <span class="term-list-card__cta">ページを開く</span>
    <span class="term-list-card__arrow" aria-hidden="true">→</span>
  </div>
</a>
