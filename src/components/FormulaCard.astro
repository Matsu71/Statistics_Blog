---
import MathText from './MathText.astro';
import { renderDisplayMath } from '../lib/math';

interface Formula {
  name: string;
  latex: string;
  description: string;
  conditions?: string[];
}

interface Props {
  formula: Formula;
}

const { formula } = Astro.props;
const renderedFormula = renderDisplayMath(formula.latex);
---

<article class="detail-card formula-card">
  <div class="formula-card__header">
    <p class="formula-card__eyebrow">定義の式</p>
    <h3>{formula.name}</h3>
  </div>
  <p class="formula-card__lead">
    <MathText text={formula.description} />
  </p>
  <div class="formula-block" aria-label={`${formula.name} の式`} set:html={renderedFormula}></div>
  {formula.conditions && formula.conditions.length > 0 && (
    <div class="formula-card__conditions">
      <p class="formula-card__conditions-title">記号の見方</p>
      <ul class="simple-list">
        {formula.conditions.map((condition) => (
          <li>
            <MathText text={condition} />
          </li>
        ))}
      </ul>
    </div>
  )}
</article>
