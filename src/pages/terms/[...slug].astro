---
import { render } from 'astro:content';
import CollapsibleSection from '../../components/CollapsibleSection.astro';
import FormulaCard from '../../components/FormulaCard.astro';
import MathText from '../../components/MathText.astro';
import RelatedTermsPanel from '../../components/RelatedTermsPanel.astro';
import SectionNav from '../../components/SectionNav.astro';
import TermHero from '../../components/TermHero.astro';
import TermSection from '../../components/TermSection.astro';
import VisualExplanationPanel from '../../components/VisualExplanationPanel.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getContentLevelLabel,
  getExamScopeLabels,
  getPublishedTerms,
  getTermCategoryLabel,
  getTermHref
} from '../../lib/content';
import { formatDate, withBase } from '../../lib/site';

export async function getStaticPaths() {
  const terms = await getPublishedTerms();

  return terms.map((term) => ({
    params: { slug: term.data.slug },
    props: { term }
  }));
}

const { term } = Astro.props;
const allTerms = await getPublishedTerms();
const relatedTerms = allTerms.filter((entry) => term.data.related_terms.includes(entry.data.slug));
const hasMarkdownBody = (term.body?.trim().length ?? 0) > 0;
const { Content } = await render(term);

const takeaways = [
  term.data.short_definition,
  term.data.where_it_appears[0] ?? 'TODO: この用語が出てくる場面を追加します。',
  term.data.exam_points[0] ?? 'TODO: 試験での重要ポイントを追加します。'
];

const sectionLinks = [
  { id: 'takeaways', text: '30秒で要点' },
  { id: 'intuition', text: 'まずはイメージで理解する' },
  ...(term.data.visual_explanation.length > 0
    ? [{ id: 'visual-explanation', text: '視覚的な説明' }]
    : []),
  { id: 'definition', text: '定義' },
  { id: 'real-world', text: '現実でどう現れるか' },
  { id: 'exam-points', text: '試験で重要なポイント' },
  ...(term.data.formulas.length > 0 ? [{ id: 'formulas', text: '数式とその意味' }] : []),
  ...(term.data.common_mistakes.length > 0
    ? [{ id: 'common-mistakes', text: 'よくある勘違い' }]
    : []),
  ...(term.data.rigorous_explanation.length > 0 || term.data.proof
    ? [{ id: 'rigor', text: '厳密な説明・証明' }]
    : []),
  { id: 'related-terms', text: '関連用語' },
  ...(hasMarkdownBody ? [{ id: 'notes', text: '補足ノート' }] : []),
  ...(term.data.references.length > 0 ? [{ id: 'references', text: '参考文献' }] : [])
];

const visualVariant =
  term.data.slug === 'variance'
    ? 'spread'
    : term.data.slug === 'normal-distribution'
      ? 'distribution'
      : term.data.slug === 'mean'
        ? 'balance'
        : 'generic';
---

<BaseLayout
  title={term.data.title}
  description={term.data.short_definition}
  ogType="article"
  updatedAt={term.data.updated_at}
>
  <section class="page-hero">
    <div class="site-shell article-layout">
      <article class="article-card article-card--term">
        <TermHero
          title={term.data.title}
          summary={term.data.short_definition}
          facts={[
            {
              label: 'カテゴリ',
              value: getTermCategoryLabel(term.data.category)
            },
            {
              label: '難易度',
              value: getContentLevelLabel(term.data.level)
            },
            {
              label: '対象',
              value: getExamScopeLabels(term.data.exam_scope).join('・')
            },
            {
              label: '更新',
              value: formatDate(term.data.updated_at)
            }
          ]}
          aliases={term.data.aliases}
          tags={term.data.tags}
          takeaways={takeaways}
        >
          <a class="ghost-link" href={withBase('/terms/')}>用語一覧へ戻る</a>
          <a class="ghost-link" href={withBase('/topics/')}>分野解説一覧</a>
        </TermHero>

        <div class="term-mobile-nav">
          <SectionNav items={sectionLinks} title="このページの目次" />
        </div>

        <div class="term-prose">
          <TermSection
            id="intuition"
            title="まずはイメージで理解する"
            intro="式の前に、この用語が何を見ているのかを言葉でつかみます。"
          >
            {term.data.intuition.map((item) => (
              <p>
                <MathText text={item} />
              </p>
            ))}
          </TermSection>

          {term.data.visual_explanation.length > 0 && (
            <TermSection
              id="visual-explanation"
              title="視覚的な説明"
              intro="画像がなくても読めるように、簡易図と短い説明をセットにしています。"
            >
              <VisualExplanationPanel items={term.data.visual_explanation} variant={visualVariant} />
            </TermSection>
          )}

          <TermSection
            id="definition"
            title="定義"
            intro="直感のあとで、言葉としての定義をここで固定します。"
          >
            <p>
              <MathText text={term.data.definition} />
            </p>
          </TermSection>

          <TermSection
            id="real-world"
            title="現実でどう現れるか"
            intro="試験の文脈と日常・実務の文脈を行き来しながら、この用語の居場所を確認します。"
          >
            <div class="split-panel">
              <div class="detail-card">
                <h3>よく出てくる場面</h3>
                <div class="bullet-tiles">
                  {term.data.where_it_appears.map((item) => (
                    <p class="bullet-tile">
                      <MathText text={item} />
                    </p>
                  ))}
                </div>
              </div>

              {term.data.practical_examples.length > 0 && (
                <div class="stack-list">
                  {term.data.practical_examples.map((example) => (
                    <article class="detail-card detail-card--example">
                      <h3>{example.title}</h3>
                      <p>
                        <MathText text={example.description} />
                      </p>
                    </article>
                  ))}
                </div>
              )}
            </div>
          </TermSection>

          <TermSection
            id="exam-points"
            title="試験で重要なポイント"
            intro="時間がないときは、この節だけでも先に確認すると着眼点を押さえやすくなります。"
            tone="accent"
          >
            <div class="point-grid">
              {term.data.exam_points.map((point) => (
                <article class="point-card point-card--accent">
                  <p>
                    <MathText text={point} />
                  </p>
                </article>
              ))}
            </div>
          </TermSection>

          {term.data.formulas.length > 0 && (
            <TermSection
              id="formulas"
              title="数式とその意味"
              intro="式は単独で覚えるのではなく、記号の意味と一緒に確認します。"
            >
              <div class="formula-grid">
                {term.data.formulas.map((formula) => (
                  <FormulaCard formula={formula} />
                ))}
              </div>
            </TermSection>
          )}

          {term.data.common_mistakes.length > 0 && (
            <TermSection
              id="common-mistakes"
              title="よくある勘違い"
              intro="似た概念との違いをここで整理しておくと、試験でも混線しにくくなります。"
              tone="subtle"
            >
              <div class="point-grid">
                {term.data.common_mistakes.map((mistake) => (
                  <article class="point-card point-card--warning">
                    <p>
                      <MathText text={mistake} />
                    </p>
                  </article>
                ))}
              </div>
            </TermSection>
          )}

          {(term.data.rigorous_explanation.length > 0 || term.data.proof) && (
            <TermSection
              id="rigor"
              title="厳密な説明・証明"
              intro="主導線を邪魔しないように、詳しい説明は折りたたみで分けています。"
            >
              {term.data.rigorous_explanation.length > 0 && (
                <CollapsibleSection
                  title="厳密な説明を読む"
                  summary="定義の背景や前提を、もう一歩ていねいに確認します。"
                  tone="rigor"
                >
                  {term.data.rigorous_explanation.map((item) => (
                    <p>
                      <MathText text={item} />
                    </p>
                  ))}
                </CollapsibleSection>
              )}

              {term.data.proof && (
                <CollapsibleSection
                  title="証明の流れを見る"
                  summary={term.data.proof.summary}
                  tone="proof"
                >
                  {term.data.proof.outline_steps.length > 0 && (
                    <ol class="simple-list proof-steps">
                      {term.data.proof.outline_steps.map((step) => (
                        <li>
                          <MathText text={step} />
                        </li>
                      ))}
                    </ol>
                  )}
                </CollapsibleSection>
              )}
            </TermSection>
          )}

          <TermSection
            id="related-terms"
            title="関連用語"
            intro="1語だけで閉じず、近い概念へ横移動すると理解がつながりやすくなります。"
          >
            {relatedTerms.length > 0 ? (
              <RelatedTermsPanel terms={relatedTerms} />
            ) : (
              <p>TODO: 関連用語の公開ページが増えたら、ここに導線を追加します。</p>
            )}
          </TermSection>

          {hasMarkdownBody && (
            <TermSection
              id="notes"
              title="補足ノート"
              intro="本文で伝えきれない背景や、周辺概念とのつながりを短く補います。"
            >
              <div class="prose">
                <Content />
              </div>
            </TermSection>
          )}

          {term.data.references.length > 0 && (
            <TermSection
              id="references"
              title="参考文献"
              intro="追加確認に使える資料だけを載せています。未確認の文献は入れていません。"
            >
              <ul class="simple-list">
                {term.data.references.map((reference) => (
                  <li>
                    {reference.url ? <a href={reference.url}>{reference.title}</a> : reference.title}
                    {reference.author && ` / ${reference.author}`}
                    {reference.year && ` / ${reference.year}`}
                    {reference.note && ` / ${reference.note}`}
                  </li>
                ))}
              </ul>
            </TermSection>
          )}
        </div>
      </article>

      <aside class="toc-card term-aside" aria-labelledby="term-sidebar-title">
        <h2 id="term-sidebar-title">ページ内の導線</h2>
        <SectionNav items={sectionLinks} />

        <div class="toc-card__section">
          <h2>関連用語</h2>
          {relatedTerms.length > 0 ? (
            <div class="mini-related-grid">
              {relatedTerms.map((relatedTerm) => (
                <a class="mini-related-card" href={withBase(getTermHref(relatedTerm))}>
                  <span class="mini-related-card__title">{relatedTerm.data.title}</span>
                  <span class="mini-related-card__description">{relatedTerm.data.short_definition}</span>
                </a>
              ))}
            </div>
          ) : (
            <p class="muted-text">公開済みの関連ページが増えたら、ここから移動できます。</p>
          )}
        </div>

        <div class="toc-card__section toc-card__actions">
          <a class="button-link" href={withBase('/terms/')}>用語一覧から探す</a>
          <a class="ghost-link" href={withBase('/topics/')}>分野解説を見る</a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
