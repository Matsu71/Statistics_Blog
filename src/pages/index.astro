---
import ContentCard from '../components/ContentCard.astro';
import PageHero from '../components/PageHero.astro';
import termIndex from '../generated/term-index.json';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  getContentLevelLabel,
  getExamScopeLabels,
  getPublishedTopics,
  getTermCategoryLabel
} from '../lib/content';
import { withBase } from '../lib/site';

const terms = termIndex.publishedTerms;
const topics = await getPublishedTopics();
type FeaturedTerm = (typeof terms)[number];
const featuredTerms = termIndex.featuredTermSlugs
  .map((slug) => terms.find((term) => term.slug === slug))
  .filter((term): term is FeaturedTerm => Boolean(term));
const nextTerm = termIndex.nextTerm;
const queuedRemaining = termIndex.stats.draftCount + termIndex.stats.unstartedCount;
---

<BaseLayout
  title="ホーム"
  description="統計検定2級向けの学習用語集サイト。まずは1用語1ページで理解を積み上げる構成です。"
>
  <PageHero
    eyebrow="Prototype"
    title="1用語1ページで、統計の理解を少しずつ積み上げる"
    description="文系の初学者でも入口で迷いにくく、それでいて試験と理解の両方に届くことを目指した学習サイトです。"
  >
    <div class="hero-actions">
      <a class="button-link" href={withBase('/terms/')}>用語一覧を見る</a>
      <a class="ghost-link" href={withBase('/topics/')}>分野解説の準備状況を見る</a>
    </div>

    <div class="stats-grid" aria-label="サイトの状況">
      <div class="stat-card">
        <p class="stat-label">公開中の用語</p>
        <p class="stat-value">{termIndex.stats.publishedCount}</p>
      </div>
      <div class="stat-card">
        <p class="stat-label">公開中の分野解説</p>
        <p class="stat-value">{topics.length}</p>
      </div>
      <div class="stat-card">
        <p class="stat-label">想定更新単位</p>
        <p class="stat-value">1語/回</p>
      </div>
      <div class="stat-card">
        <p class="stat-label">キュー残り</p>
        <p class="stat-value">{queuedRemaining}</p>
      </div>
    </div>

    {nextTerm && (
      <p class="section-text" style="margin-top: 1rem;">
        次に追加予定の用語は「{nextTerm.title}」です。queue から 1 語ずつ足していく前提で、案内も自動更新されます。
      </p>
    )}
  </PageHero>

  <section class="page-section">
    <div class="site-shell">
      <div class="section-head">
        <div>
          <h2 class="section-title">このサイトの使い方</h2>
          <p class="section-text">
            まずは用語ページを主軸にし、将来は複数の用語を束ねた分野解説へ発展できるように分けています。
          </p>
        </div>
      </div>

      <div class="card-grid">
        <div class="content-card">
          <h2 class="content-card__title">1. 用語から入る</h2>
          <p class="muted-text">
            「平均」「分散」のような単位で知識を切り出し、必要な理解を小さく積み上げます。
          </p>
        </div>
        <div class="content-card">
          <h2 class="content-card__title">2. 理解を深める</h2>
          <p class="muted-text">
            各ページ内でイメージ、定義、試験での重要点、数式という順に理解を深めます。
          </p>
        </div>
        <div class="content-card">
          <h2 class="content-card__title">3. 分野でまとめる</h2>
          <p class="muted-text">
            将来は確率、推定、検定のような重要分野を、用語ページを再利用して解説します。
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="site-shell">
      <div class="section-head">
        <div>
          <h2 class="section-title">最初に読むデモページ</h2>
          <p class="section-text">
            UI とテンプレート確認用に、初学者が読み進めやすい形のサンプルを配置しています。
          </p>
        </div>
        <a class="ghost-link" href={withBase('/terms/')}>すべての用語を見る</a>
      </div>

      <div class="card-grid">
        {featuredTerms.map((term) => (
          <ContentCard
            href={withBase(term.href)}
            title={term.title}
            description={term.shortDefinition}
            meta={`${getTermCategoryLabel(term.category)} / ${getExamScopeLabels(
              term.examScope
            ).join('・')}`}
            badges={[getContentLevelLabel(term.level), ...term.tags.slice(0, 2)]}
            searchText={term.searchText}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
