---
import ContentCard from '../components/ContentCard.astro';
import PageHero from '../components/PageHero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/site';
---

<BaseLayout
  title="ホーム"
  description="統計検定2級向けの学習用語集です。"
>
  <PageHero
    eyebrow="Glossary"
    title="統計ことばノート"
    description="統計検定2級の用語を、1語ずつ整理する学習ノートです。"
  >
    <div class="hero-actions">
      <a class="button-link" href={withBase('/terms/')}>用語一覧を見る</a>
      <a class="ghost-link" href={withBase('/topics/')}>分野解説を見る</a>
    </div>
  </PageHero>

  <section class="page-section page-section--compact">
    <div class="site-shell">
      <div class="section-head">
        <div>
          <h2 class="section-title">入口</h2>
        </div>
      </div>

      <div class="card-grid">
        <ContentCard
          href={withBase('/terms/')}
          title="用語一覧"
          description="定義と試験ポイントを用語ごとに確認できます。"
        />
        <ContentCard
          href={withBase('/topics/')}
          title="分野解説"
          description="関連する用語をまとまりで確認できます。"
        />
      </div>
    </div>
  </section>
</BaseLayout>
