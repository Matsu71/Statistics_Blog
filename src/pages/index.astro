---
import ContentCard from '../components/ContentCard.astro';
import PageHero from '../components/PageHero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/site';
---

<BaseLayout
  title="ホーム"
  description="統計の用語、考え方、数式、試験ポイントを整理する学習サイトです。"
>
  <PageHero
    eyebrow="Glossary"
    title="統計ラボ"
    description="統計を基礎から学ぶために、用語・考え方・数式・試験ポイントを1ページずつ整理しています。"
  >
    <div class="hero-actions">
      <a class="button-link" href={withBase('/terms/')}>用語一覧を見る</a>
      <a class="ghost-link" href={withBase('/topics/')}>分野解説を見る</a>
    </div>
    <div class="hero-tile-grid" slot="aside">
      <article class="hero-mini-card hero-mini-card--accent">
        <strong class="hero-mini-card__value">用語一覧</strong>
      </article>
    </div>
  </PageHero>

  <section class="page-section page-section--compact">
    <div class="site-shell">
      <div class="section-head">
        <div>
          <h2 class="section-title">入口</h2>
        </div>
      </div>

      <div class="card-grid">
        <ContentCard
          href={withBase('/terms/')}
          title="用語一覧"
          description="定義、例、数式、試験ポイントを用語ごとに確認できます。"
        />
        <ContentCard
          href={withBase('/topics/')}
          title="分野解説"
          description="関連する用語をまとまりで確認できます。"
        />
      </div>
    </div>
  </section>

</BaseLayout>
