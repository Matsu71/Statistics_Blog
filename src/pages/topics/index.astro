---
import ContentCard from '../../components/ContentCard.astro';
import EmptyState from '../../components/EmptyState.astro';
import PageHero from '../../components/PageHero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getContentLevelLabel,
  getExamScopeLabels,
  getPublishedTopics,
  getTopicHref,
  getTopicTypeLabel
} from '../../lib/content';
import { withBase } from '../../lib/site';

const topics = await getPublishedTopics();
---

<BaseLayout
  title="分野解説"
  description="関連するテーマをまとめる一覧です。"
>
  <PageHero
    eyebrow="Topics"
    title="分野解説"
    description="近い用語をまとめて読み、全体像をつかめます。"
  >
    <div class="hero-actions">
      <a class="button-link" href={withBase('/')}>ホームへ</a>
      <a class="ghost-link" href={withBase('/terms/')}>用語一覧へ</a>
    </div>
    <div class="hero-panel hero-panel--compact" slot="aside">
      <p class="hero-panel__eyebrow">Bridge</p>
      <h2 class="hero-panel__title">分野解説の役割</h2>
      <ul class="hero-panel__list">
        <li>近い用語をまとめて見渡せます。</li>
        <li>全体像をつかんでから個別ページへ戻れます。</li>
      </ul>
    </div>
  </PageHero>

  <section class="page-section">
    <div class="site-shell">
      <div class="section-head">
        <div>
          <h2 class="section-title">一覧</h2>
          <p class="section-text">関連するテーマをまとめています。</p>
        </div>
      </div>

      {topics.length > 0 ? (
        <div class="topic-grid">
          {topics.map((topic) => (
            <ContentCard
              href={withBase(getTopicHref(topic))}
              title={topic.data.title}
              description={topic.data.summary}
              meta={`${getTopicTypeLabel(topic.data.topic_type)} / ${getExamScopeLabels(
                topic.data.exam_scope
              ).join('・')}`}
              badges={[getContentLevelLabel(topic.data.level), ...topic.data.related_terms]}
              searchText={[
                topic.data.title,
                topic.data.summary,
                ...topic.data.learning_goals,
                ...topic.data.related_terms
              ].join(' ')}
            />
          ))}
        </div>
      ) : (
        <EmptyState title="準備中" description="ここへ追加します。" />
      )}
    </div>
  </section>
</BaseLayout>
