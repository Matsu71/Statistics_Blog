---
import ContentCard from '../../components/ContentCard.astro';
import EmptyState from '../../components/EmptyState.astro';
import PageHero from '../../components/PageHero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getContentLevelLabel,
  getExamScopeLabels,
  getPublishedTopics,
  getTopicHref,
  getTopicTypeLabel
} from '../../lib/content';
import { withBase } from '../../lib/site';

const topics = await getPublishedTopics();
---

<BaseLayout
  title="分野解説"
  description="関連するテーマをまとめる一覧です。"
>
  <PageHero
    title="分野解説"
    description="関連するテーマをまとめるページです。"
  />

  <section class="page-section">
    <div class="site-shell">
      {topics.length > 0 ? (
        <div class="topic-grid">
          {topics.map((topic) => (
            <ContentCard
              href={withBase(getTopicHref(topic))}
              title={topic.data.title}
              description={topic.data.summary}
              meta={`${getTopicTypeLabel(topic.data.topic_type)} / ${getExamScopeLabels(
                topic.data.exam_scope
              ).join('・')}`}
              badges={[getContentLevelLabel(topic.data.level), ...topic.data.related_terms]}
              searchText={[
                topic.data.title,
                topic.data.summary,
                ...topic.data.learning_goals,
                ...topic.data.related_terms
              ].join(' ')}
            />
          ))}
        </div>
      ) : (
        <EmptyState title="準備中" description="公開後にここへ追加します。" />
      )}
    </div>
  </section>
</BaseLayout>
