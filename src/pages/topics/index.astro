---
import ContentCard from '../../components/ContentCard.astro';
import EmptyState from '../../components/EmptyState.astro';
import PageHero from '../../components/PageHero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getContentLevelLabel,
  getExamScopeLabels,
  getPublishedTopics,
  getTopicHref,
  getTopicTypeLabel
} from '../../lib/content';
import { withBase } from '../../lib/site';

const topics = await getPublishedTopics();
---

<BaseLayout
  title="分野解説"
  description="将来的に確率、推定、検定などの重要分野をまとめるための一覧ページです。"
>
  <PageHero
    eyebrow="Topics"
    title="重要分野の解説ページを、あとから積み上げる"
    description="今は空の受け皿ですが、用語ページが増えたあとに分野ごとのまとめ記事を追加できるように分けています。"
  />

  <section class="page-section">
    <div class="site-shell">
      {topics.length > 0 ? (
        <div class="topic-grid">
          {topics.map((topic) => (
            <ContentCard
              href={withBase(getTopicHref(topic))}
              title={topic.data.title}
              description={topic.data.summary}
              meta={`${getTopicTypeLabel(topic.data.topic_type)} / ${getExamScopeLabels(
                topic.data.exam_scope
              ).join('・')}`}
              badges={[getContentLevelLabel(topic.data.level), ...topic.data.related_terms]}
              searchText={[
                topic.data.title,
                topic.data.summary,
                ...topic.data.learning_goals,
                ...topic.data.related_terms
              ].join(' ')}
            />
          ))}
        </div>
      ) : (
        <EmptyState
          title="分野解説ページはまだ未着手です"
          description="まずは `src/content/terms/` に用語ページを蓄積し、その後で `src/content/topics/` に統合的な解説を追加する想定です。"
        />
      )}
    </div>
  </section>
</BaseLayout>
