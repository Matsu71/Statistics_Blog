---
import ContentCard from '../../components/ContentCard.astro';
import EmptyState from '../../components/EmptyState.astro';
import PageHero from '../../components/PageHero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getContentLevelLabel,
  getExamScopeLabels,
  getPublishedTopics,
  getTopicHref,
  getTopicTypeLabel
} from '../../lib/content';
import { withBase } from '../../lib/site';

const topics = await getPublishedTopics();
---

<BaseLayout
  title="分野解説"
  description="関連するテーマをまとめる一覧です。"
>
  <PageHero
    eyebrow="Topics"
    title="分野解説"
    description="近い用語をまとめて読み、個別ページを行き来しながら全体像をつかめます。"
  >
    <div class="hero-actions">
      <a class="button-link" href={withBase('/')}>ホームへ</a>
      <a class="ghost-link" href={withBase('/terms/')}>用語一覧へ</a>
    </div>
    <div class="hero-tile-grid" slot="aside">
      <article class="hero-mini-card">
        <span class="hero-mini-card__label">公開中</span>
        <strong class="hero-mini-card__value">{topics.length}</strong>
        <span class="hero-mini-card__meta">関連テーマを少しずつ追加しています</span>
      </article>
      <article class="hero-mini-card">
        <span class="hero-mini-card__label">役割</span>
        <strong class="hero-mini-card__value">橋渡し</strong>
        <span class="hero-mini-card__meta">個別の用語どうしをつなげて理解します</span>
      </article>
    </div>
  </PageHero>

  <section class="page-section">
    <div class="site-shell">
      <div class="section-head">
        <div>
          <h2 class="section-title">一覧</h2>
          <p class="section-text">関連するテーマをまとめています。</p>
        </div>
      </div>

      {topics.length > 0 ? (
        <div class="topic-grid">
          {topics.map((topic) => (
            <ContentCard
              href={withBase(getTopicHref(topic))}
              title={topic.data.title}
              description={topic.data.summary}
              meta={`${getTopicTypeLabel(topic.data.topic_type)} / ${getExamScopeLabels(
                topic.data.exam_scope
              ).join('・')}`}
              badges={[getContentLevelLabel(topic.data.level), ...topic.data.related_terms]}
              searchText={[
                topic.data.title,
                topic.data.summary,
                ...topic.data.learning_goals,
                ...topic.data.related_terms
              ].join(' ')}
            />
          ))}
        </div>
      ) : (
        <EmptyState title="準備中" description="ここへ追加します。" />
      )}
    </div>
  </section>
</BaseLayout>
